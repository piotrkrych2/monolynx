# PostgreSQL
POSTGRES_DB=open_sentry
POSTGRES_USER=sentry
POSTGRES_PASSWORD=sentry_dev

# Ports
DB_PORT=5432
APP_PORT=8000

# Application
ENVIRONMENT=development
LOG_LEVEL=debug
APP_URL=http://localhost:8000
# SECRET_KEY -- WYMAGANY w produkcji! Wygeneruj: python -c "import secrets; print(secrets.token_urlsafe(64))"
# SECRET_KEY=

# MCP (dozwolone hosty dla serwera MCP, oddzielone przecinkami)
# MCP_ALLOWED_HOSTS=open.monolynx.com

# SMTP (pusty SMTP_HOST = email wylaczony)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@monolynx.local
SMTP_USE_TLS=true

# MinIO (storage dla wiki)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=monolynx-wiki

# Neo4j (graf baza danych)
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_dev
ENABLE_GRAPH_DB=true

# Wiki RAG Search (pusty OPENAI_API_KEY = embeddings wylaczone)
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

MONOLYNX_URL=https://open.monolynx.com
MONOLYNX_GRAPH_TOKEN=
MONOLYNX_PROJECT_SLUG=monolynx
