#local
  {
    "mcpServers": {
      "monolynx": {
        "command": "npx",
        "args": [
          "-y",
          "mcp-remote",
          "https://open.monolynx.com/mcp/",
          "--header",
          "Authorization: Bearer osk_<...>"
        ]
      }
    }
  }

# prod
  {
    "mcpServers": {
      "monolynx": {
        "command": "npx",
        "args": [
          "-y",
          "mcp-remote",
          "https://open.monolynx.com/mcp/",
          "--header",
          "Authorization: Bearer osk_<...>"
        ]
      }
    }
  }
